<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.29.xsd">

    <changeSet id="3-create-bankcards-table" author="ivanov">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="bankcards"/>
            </not>
        </preConditions>
        
        <createTable tableName="bankcards">
            <!-- ID -->
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            
            <!-- Хэш номера карты (для поиска) -->
            <column name="hash" type="VARCHAR(255)">
                <constraints unique="true" nullable="false"/>
            </column>
            
            <!-- Зашифрованный номер карты -->
            <column name="encrypted" type="TEXT">
                <constraints nullable="false"/>
            </column>
            
            <!-- Последние 4 цифры (для отображения) -->
            <column name="lastdigits" type="VARCHAR(4)">
                <constraints nullable="false"/>
            </column>
            
            <!-- Статус карты -->
            <column name="status" type="VARCHAR(50)" defaultValue="ACTIVE">
                <constraints nullable="false"/>
            </column>
            
            <!-- Баланс -->
            <column name="balance" type="DECIMAL(19,2)" defaultValueNumeric="0.00">
                <constraints nullable="false"/>
            </column>
            
            <!-- Связь с владельцем -->
            <column name="card_holder_id" type="BIGINT">
                <constraints nullable="false" 
                           foreignKeyName="fk_bankcards_card_holder"
                           referencedTableName="cardholders" 
                           referencedColumnNames="id"/>
            </column>
            
            <!-- Временные метки -->
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>
        
        <!-- Индексы для быстрого поиска -->
        <createIndex indexName="idx_bankcards_hash" tableName="bankcards">
            <column name="hash"/>
        </createIndex>
        
        <createIndex indexName="idx_bankcards_lastdigits" tableName="bankcards">
            <column name="lastdigits"/>
        </createIndex>
        
        <createIndex indexName="idx_bankcards_card_holder_id" tableName="bankcards">
            <column name="card_holder_id"/>
        </createIndex>
        
        <createIndex indexName="idx_bankcards_status" tableName="bankcards">
            <column name="status"/>
        </createIndex>
        
        <comment>Creating bankcards table with secure card storage (hash, encrypted, lastdigits)</comment>
    </changeSet>

    <changeSet id="4-grant-bankcards-permissions" author="ivanov" runOnChange="true">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="bankcards"/>
        </preConditions>
        
        <sql dbms="postgresql">
            GRANT ALL PRIVILEGES ON TABLE bankcards TO bankrest;
        </sql>
        <sql dbms="postgresql">
            GRANT USAGE, SELECT ON SEQUENCE bankcards_id_seq TO bankrest;
        </sql>
        
        <comment>Granting permissions on bankcards table and sequence</comment>
    </changeSet>

</databaseChangeLog>